<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:singalUI.ViewModels"
             xmlns:v="using:singalUI.Views"
             x:Class="singalUI.Views.AnalysisView"
             x:DataType="vm:AnalysisViewModel"
             Background="#1a1a1a">

    <Design.DataContext>
        <vm:AnalysisViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,280">
        <!-- Chart Controls Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#2a2a2a"
                BorderBrush="#404040"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <Border Width="20" Height="20" VerticalAlignment="Center">
                        <Path Data="M3 17h2v-4H3v4zm4 0h2V7H7v10zm4 0h2v-7h-2v7zm4 0h2V3h-2v14z"
                              Fill="#999999" 
                              Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="Show:"
                               FontSize="14"
                               FontWeight="Medium"
                               Foreground="#ffffff"
                               VerticalAlignment="Center"/>

                    <CheckBox Content="X" IsChecked="{Binding ShowX}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Y" IsChecked="{Binding ShowY}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Z" IsChecked="{Binding ShowZ}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Rx" IsChecked="{Binding ShowRx}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Ry" IsChecked="{Binding ShowRy}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Rz" IsChecked="{Binding ShowRz}" FontSize="14" Foreground="#ffffff"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Border Background="#202020"
                            BorderBrush="#505050"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="6,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="2D"
                                    Command="{Binding ShowSix2DPlotsCommand}"
                                    Padding="10,6"
                                    FontSize="13"/>
                            <Button Content="3D"
                                    Command="{Binding ShowSingle3DPlotCommand}"
                                    Padding="10,6"
                                    FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Points" IsChecked="{Binding ShowPoints}" FontSize="14" Foreground="#ffffff"/>
                    <CheckBox Content="Mesh" IsChecked="{Binding ShowMesh}" FontSize="14" Foreground="#ffffff"/>
                    <Button Content="{Binding FullScreenButtonLabel}"
                            Command="{Binding ToggleFullScreenCommand}"
                            Padding="12,8"
                            FontSize="13"
                            Background="#404040"
                            Foreground="#ffffff"
                            BorderBrush="#505050"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Visualization Area -->
        <Border Grid.Row="1" Grid.Column="0" 
                Margin="16,16,8,16"
                Background="#0d0d0d"
                BorderBrush="#333333"
                BorderThickness="2"
                CornerRadius="0">
            <Grid>
                <!-- Empty State (No data and no status message) -->
                <Border IsVisible="{Binding !HasData}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <!-- Show icon and default message when no status message -->
                        <Border Width="80" Height="80" 
                                Background="#2a2a2a"
                                CornerRadius="40"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding !HasStatusMessage}">
                            <Path Data="M3 17h2v-4H3v4zm4 0h2V7H7v10zm4 0h2v-7h-2v7zm4 0h2V3h-2v14z"
                                  Fill="#666666" 
                                  Stretch="Uniform"
                                  Width="40"
                                  Height="40"/>
                        </Border>
                        <TextBlock Text="No Pose Estimation Data"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#999999"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding !HasStatusMessage}"/>
                        <TextBlock Text="Run a pose estimation scan from the Calibration Setup tab"
                                   FontSize="14"
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   TextAlignment="Center"
                                   IsVisible="{Binding !HasStatusMessage}"/>
                        
                        <!-- Show status message when available -->
                        <Border Width="80" Height="80" 
                                Background="#3a2a2a"
                                CornerRadius="40"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding HasStatusMessage}">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                  Fill="#ff6666" 
                                  Stretch="Uniform"
                                  Width="40"
                                  Height="40"/>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="14"
                                   Foreground="#cccccc"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="500"
                                   TextAlignment="Center"
                                   IsVisible="{Binding HasStatusMessage}"/>
                    </StackPanel>
                </Border>
                
                <!-- Data Views -->
                <ScrollViewer IsVisible="{Binding IsTwoDGridMode}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ChartCards}"
                                  Padding="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <v:ChartCardView MinHeight="200"
                                                 MinWidth="0"
                                                 Margin="2"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch"
                                                 Command="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).Select2DChartCommand}"
                                                 CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <v:ChartCardView DataContext="{Binding Selected2DChart}"
                                 IsVisible="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).IsSelected2DChartFullScreen}"
                                 Margin="16"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>

                <v:Simple3DView 
                    x:Name="Visualization3D"
                    IsVisible="{Binding IsSingle3DMode}"
                    Data="{Binding Visualization3DData}"
                    ShowGrid="{Binding ShowGrid}"
                    ShowPoints="{Binding ShowPoints}"
                    ShowMesh="{Binding ShowMesh}"
                    ShowLines="True"/>
            </Grid>
        </Border>

        <!-- Right Panel - Scrollable -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20" Margin="8,16,16,12">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                                <Path Data="M3 17h2v-4H3v4zm4 0h2V7H7v10zm4 0h2v-7h-2v7zm4 0h2V3h-2v14z"
                                      Fill="#999999" 
                                      Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Statistics" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" Margin="12,0,12,0"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ChartCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" Margin="0,6,0,6">
                                        <TextBlock Grid.Column="0" Text="{Binding StatLabel}" FontSize="14" Foreground="#ffffff" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StatValue}" FontSize="14" Foreground="#ffffff"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Background="#303030" BorderBrush="#505050" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Overall:" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Overall_Rms}" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Preview Mode -->
            <Border Grid.Row="1" Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20" Margin="8,0,16,12">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                            <Path Data="M10 4C5.5 4 1.73 7.11 0 11.5 1.73 15.89 5.5 19 10 19s8.27-3.11 10-7.5C18.27 7.11 14.5 4 10 4zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                  Fill="#999999" 
                                  Stretch="Uniform"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Preview Mode" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" Margin="12,0,12,0"/>
                    </Grid>

                    <TextBlock Text="Open a previously saved calibration folder to view plots and captured images."
                               FontSize="12"
                               Foreground="#ffffff"
                               TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding PreviewDataFolder, StringFormat={}{0}}"
                                   FontSize="13"
                                   Foreground="#ffffff"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{Binding BrowsePreviewFolderCommand}"
                                Padding="10,6"
                                FontSize="12"
                                MinWidth="80"/>
                    </Grid>

                    <Button Content="Load Preview Data"
                            Command="{Binding LoadPreviewDataCommand}"
                            Padding="16,12"
                            FontSize="14"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasPreviewData}"/>

                    <!-- Preview Info -->
                    <Border IsVisible="{Binding HasPreviewData}"
                            Background="#1a1a1a"
                            BorderBrush="#303030"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Images:" FontSize="12" Foreground="#ffffff"/>
                                <TextBlock Grid.Column="1" Text="{Binding PreviewImageCount}" FontSize="12" Foreground="#ffffff" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Data Points:" FontSize="12" Foreground="#ffffff"/>
                                <TextBlock Grid.Column="1" Text="{Binding PreviewDataPoints}" FontSize="12" Foreground="#ffffff" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Date:" FontSize="12" Foreground="#ffffff"/>
                                <TextBlock Grid.Column="1" Text="{Binding PreviewDate}" FontSize="12" Foreground="#ffffff" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20" Margin="8,0,16,12">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                            <Path Data="M5 18h10v2H5v-2zm5-14v9.17l-2.59-2.58L6 12l4 4 4-4-1.41-1.41L10 13.17V4h-2z"
                                  Fill="#999999" 
                                  Stretch="Uniform"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Export Data" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" Margin="12,0,12,0"/>
                    </Grid>
                    <Button Content="Export to CSV" Command="{Binding ExportCsvCommand}" Padding="16,12" FontSize="14" HorizontalAlignment="Stretch"/>
                    <Button Content="Export to JSON" Command="{Binding ExportJsonCommand}" Padding="16,12" FontSize="14" HorizontalAlignment="Stretch"/>
                    <Button Content="Save Plots as PNG" Command="{Binding ExportPngCommand}" Padding="16,12" FontSize="14" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- Error Log -->
            <Border Grid.Row="3" Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20" Margin="8,0,16,12">
                <StackPanel Spacing="16">
                    <!-- Section Header -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                            <Path Data="M10 2c-4.41 0-8 3.59-8 8s3.59 8 8 8 8-3.59 8-8-3.59-8-8-8zm1 13H9v-2h2v2zm0-4H9V5h2v6z"
                                  Fill="#ba68c8" 
                                  Stretch="Uniform"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Error Log"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#ffffff"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </Grid>

                    <ScrollViewer MaxHeight="300" HorizontalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding ErrorLog}"
                                   IsReadOnly="True"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   BorderThickness="0"
                                   FontSize="11"
                                   Foreground="#ffffff"
                                   FontFamily="Consolas,Courier New"
                                   Background="Transparent"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Content="Generate Report" Command="{Binding GenerateReportCommand}" Padding="20,12" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
