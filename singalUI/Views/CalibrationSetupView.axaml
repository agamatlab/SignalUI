<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:singalUI.ViewModels"
             xmlns:m="using:singalUI.Models"
             xmlns:s="using:singalUI.Services"
             x:Class="singalUI.Views.CalibrationSetupView"
             x:DataType="vm:CalibrationSetupViewModel"
             Background="#1a1a1a">

    <Design.DataContext>
        <vm:CalibrationSetupViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,300">
        <!-- Sampling Mode Selector -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#2a2a2a"
                BorderBrush="#404040"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Stage"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#ffffff"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                    <RadioButton Content="Manual"
                                 GroupName="SamplingMode"
                                 IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Manual}"
                                 FontSize="14"
                                 Foreground="#ffffff"/>
                    <RadioButton Content="Triggered"
                                 GroupName="SamplingMode"
                                 IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Triggered}"
                                 FontSize="14"
                                 Foreground="#ffffff"/>
                    <RadioButton Content="Timed"
                                 GroupName="SamplingMode"
                                 IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Timed}"
                                 FontSize="14"
                                 Foreground="#ffffff"/>
                    <RadioButton Content="Control"
                                 GroupName="SamplingMode"
                                 IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Control}"
                                 FontSize="14"
                                 Foreground="#ffffff"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                    <!-- Timed Mode Options -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding SamplingMode, Converter={StaticResource SamplingModeVisibleConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Duration (s):"
                                       FontSize="13"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown Value="{Binding TimedDuration}"
                                           Minimum="1"
                                           Maximum="3600"
                                           Increment="1"
                                           FormatString="F0"
                                           Width="130"
                                           FontSize="13"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Interval (s):"
                                       FontSize="13"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown Value="{Binding TimedInterval}"
                                           Minimum="0.1"
                                           Maximum="10"
                                           Increment="0.1"
                                           FormatString="F1"
                                           Width="130"
                                           FontSize="13"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Triggered Mode Delay -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding SamplingMode, Converter={StaticResource TriggeredModeVisibleConverter}}">
                        <TextBlock Text="Delay (ms):"
                                   FontSize="13"
                                   Foreground="#ffffff"
                                   VerticalAlignment="Center"/>
                        <NumericUpDown Value="{Binding TriggeredDelay}"
                                       Minimum="0"
                                       Maximum="10000"
                                       Increment="1"
                                       FormatString="F0"
                                       Width="100"
                                       FontSize="13"
                                       HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Control Mode Delay -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding SamplingMode, Converter={StaticResource ControlModeVisibleConverter}}">
                        <TextBlock Text="Delay (ms):"
                                   FontSize="13"
                                   Foreground="#ffffff"
                                   VerticalAlignment="Center"/>
                        <NumericUpDown Value="{Binding ControlDelay}"
                                       Minimum="0"
                                       Maximum="10000"
                                       Increment="1"
                                       FormatString="F0"
                                       Width="100"
                                       FontSize="13"
                                       HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="16,16,8,16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
        <StackPanel IsVisible="{Binding UseFullMotionTable}">
        <ItemsControl ItemsSource="{Binding StageMotionGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectedStageMotionGroup">
                    <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,12">
                        <StackPanel Spacing="0">
                            <TextBlock Text="{Binding ProductTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff" Margin="16,12,16,4" HorizontalAlignment="Left"/>

                            <Border IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).SamplingMode, Converter={StaticResource ControlModeVisibleConverter}, ConverterParameter=Invert}"
                                    Background="#252525" BorderThickness="0" Padding="0">
                                <Grid RowDefinitions="Auto,Auto,*">
                                    <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,10">
                                        <StackPanel Orientation="Horizontal" Spacing="20">
                                            <TextBlock Text="Movement Mode:" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Absolute" GroupName="{Binding MovementRadioGroup}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Relative" GroupName="{Binding MovementRadioGroup}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,12">
                                        <Grid ColumnDefinitions="50,70,*,80,160,180,120">
                                            <TextBlock Grid.Column="0" Text="On" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="1" Text="Axis" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="2" Text="Label" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="3" Text="Unit" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="4" Text="Position" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Step Size" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="Points" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#303030" BorderThickness="0,0,0,1" Padding="16,10" Background="#252525">
                                                    <Grid ColumnDefinitions="50,70,*,80,160,140,100">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Axis}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Label}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Unit}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="4" Value="{Binding TargetPosition, Mode=TwoWay}" Minimum="-1000000" Maximum="1000000" Increment="100" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}"/>
                                                        <Border Grid.Column="4" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}">
                                                            <TextBlock Text="{Binding CalculatedEndPosition, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Border Grid.Column="5" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}">
                                                            <TextBlock Text="{Binding AutoStepSize, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <NumericUpDown Grid.Column="5" Value="{Binding StepSize, Mode=TwoWay}" Minimum="0.001" Maximum="1000" Increment="1" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}"/>
                                                        <NumericUpDown Grid.Column="6" Value="{Binding NumSteps, Mode=TwoWay}" Minimum="1" Maximum="10000" Increment="1" FormatString="F0" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).SamplingMode, Converter={StaticResource ControlModeVisibleConverter}}"
                                    Background="#252525" BorderThickness="0" Padding="0">
                                <Grid RowDefinitions="Auto,Auto,*">
                                    <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,10">
                                        <StackPanel Orientation="Horizontal" Spacing="20">
                                            <TextBlock Text="Movement Mode:" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Absolute" GroupName="{Binding MovementRadioGroupB}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Relative" GroupName="{Binding MovementRadioGroupB}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,12">
                                        <Grid ColumnDefinitions="50,70,*,80,160,180,120,160">
                                            <TextBlock Grid.Column="0" Text="On" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="1" Text="Axis" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="2" Text="Label" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="3" Text="Unit" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="4" Text="Position" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Step Size" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="Points" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="Controls" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#303030" BorderThickness="0,0,0,1" Padding="16,10" Background="#252525">
                                                    <Grid ColumnDefinitions="50,70,*,80,160,180,120,160">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Axis}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Label}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Unit}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="4" Value="{Binding TargetPosition, Mode=TwoWay}" Minimum="-1000000" Maximum="1000000" Increment="100" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}"/>
                                                        <Border Grid.Column="4" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}">
                                                            <TextBlock Text="{Binding CalculatedEndPosition, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Border Grid.Column="5" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}">
                                                            <TextBlock Text="{Binding AutoStepSize, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <NumericUpDown Grid.Column="5" Value="{Binding StepSize, Mode=TwoWay}" Minimum="0.001" Maximum="1000" Increment="1" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}"/>
                                                        <NumericUpDown Grid.Column="6" Value="{Binding NumSteps, Mode=TwoWay}" Minimum="1" Maximum="10000" Increment="1" FormatString="F0" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                        <ComboBox Grid.Column="7" SelectedIndex="{Binding SelectedController, Converter={StaticResource ControllerToIndexConverter}}" PlaceholderText="Select Controller" FontSize="13" HorizontalAlignment="Stretch" IsEnabled="{Binding IsEnabled}">
                                                            <ComboBoxItem Content="None"/>
                                                            <ComboBoxItem Content="Manual Jog"/>
                                                            <ComboBoxItem Content="Auto Step"/>
                                                            <ComboBoxItem Content="PID"/>
                                                            <ComboBoxItem Content="Servo"/>
                                                            <ComboBoxItem Content="Stepper"/>
                                                            <ComboBoxItem Content="DC"/>
                                                        </ComboBox>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border Background="#1a1a1a" BorderBrush="#303030" BorderThickness="1" CornerRadius="6" Padding="12" Margin="16,12,16,8">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Current Position" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowX}">
                                        <TextBlock Text="X:" Width="36" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayX, StringFormat={}{0:F3} µm}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowY}">
                                        <TextBlock Text="Y:" Width="36" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayY, StringFormat={}{0:F3} µm}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowZ}">
                                        <TextBlock Text="Z:" Width="36" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayZ, StringFormat={}{0:F3} µm}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowRx}">
                                        <TextBlock Text="Rx:" Width="36" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayRx, StringFormat={}{0:F3} deg}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowRy}">
                                        <TextBlock Text="Ry:" Width="36" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayRy, StringFormat={}{0:F3} deg}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowRz}">
                                        <TextBlock Text="Rz:" Width="36" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayRz, StringFormat={}{0:F3} deg}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Set zero" VerticalAlignment="Center" Foreground="#bbbbbb" FontSize="12"/>
                                        <ToggleSwitch IsChecked="{Binding DisplayPositionAsRaw, Mode=TwoWay}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                                        <TextBlock Text="Display raw" VerticalAlignment="Center" Foreground="#bbbbbb" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </StackPanel>

        <!-- Rotation calibration: compact single-DOF motion (first row) -->
        <Border Background="#252525"
                BorderBrush="#404040"
                BorderThickness="1"
                CornerRadius="8"
                Padding="0"
                IsVisible="{Binding ShowRotationCompactMotion}">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <Border Grid.Row="0" Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,10">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="Movement Mode:" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                        <RadioButton Content="Absolute" GroupName="AxisMovementModeRot" IsChecked="{Binding MovementModeAbsolute}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                        <RadioButton Content="Relative" GroupName="AxisMovementModeRot" IsChecked="{Binding MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Padding="16,12" DataContext="{Binding RotationMotionRow}">
                    <Grid ColumnDefinitions="Auto,56,Auto,1*,Auto,1*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Text="Rotation θ (Rz)" FontSize="15" FontWeight="SemiBold" Foreground="#e0e0e0"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Unit" FontSize="12" Foreground="#aaaaaa" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Unit}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Position" FontSize="12" Foreground="#aaaaaa" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding TargetPosition, Mode=TwoWay}" Minimum="-360" Maximum="360" Increment="0.1" FormatString="F3" FontSize="13"
                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}"/>
                        <Border Grid.Row="1" Grid.Column="3" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}">
                            <TextBlock Text="{Binding CalculatedEndPosition, StringFormat={}{0:F3}}" FontSize="13" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="Step (deg)" FontSize="12" Foreground="#aaaaaa" VerticalAlignment="Center"/>
                        <Border Grid.Row="1" Grid.Column="5" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}">
                            <TextBlock Text="{Binding AutoStepSize, StringFormat={}{0:F3}}" FontSize="13" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <NumericUpDown Grid.Row="1" Grid.Column="5" Value="{Binding StepSize, Mode=TwoWay}" Minimum="0.001" Maximum="360" Increment="0.1" FormatString="F3" FontSize="13"
                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}"/>
                    </Grid>
                </Border>
                <Grid Grid.Row="2" Margin="16,0,16,14" ColumnDefinitions="Auto,*" ColumnSpacing="12" DataContext="{Binding RotationMotionRow}">
                    <TextBlock Grid.Column="0" Text="Points" FontSize="12" Foreground="#aaaaaa" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Column="1" Value="{Binding NumSteps, Mode=TwoWay}" Minimum="1" Maximum="10000" Increment="1" FormatString="F0" FontSize="13" HorizontalAlignment="Left" Width="120"/>
                </Grid>
            </Grid>
        </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Right Panel - Scrollable -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="8,16,16,16">
            <StackPanel Spacing="12">

                <!-- Stage Controllers -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Stage Controllers" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Add" Command="{Binding AddStageCommand}" Padding="10,6" FontSize="12" Foreground="#ffffff" HorizontalAlignment="Right"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding StageWrappers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Id, StringFormat='Stage {0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <Ellipse Grid.Row="0" Grid.Column="1" Width="12" Height="12" VerticalAlignment="Center" Margin="8,0,8,0" Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusColorConverter}}" Stroke="#505050" StrokeThickness="1"/>
                                            <Button Grid.Row="0" Grid.Column="2" Command="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).RemoveStageCommand}" CommandParameter="{Binding}" Padding="4" Background="Transparent" BorderThickness="0" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0">
                                                <Path Width="18" Height="18" Fill="#ff4444" Data="M9 3h6l1 1h4v2H4V4h4l1-1zm-3 5h14l-1 14H7L6 8zm3 3v9h2v-9H9zm4 0v9h2v-9h-2z" Stretch="Uniform"/>
                                            </Button>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Vertical" Spacing="8" Margin="0,8,0,0">
                                                <ComboBox SelectedIndex="{Binding HardwareType, Converter={StaticResource StageHardwareToIndexConverter}}" PlaceholderText="Select Hardware..." FontSize="12" Foreground="#ffffff" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="None"/>
                                                    <ComboBoxItem Content="PI 6-dof"/>
                                                    <ComboBoxItem Content="Optosigma OSMS26-100(X)"/>
                                                    <ComboBoxItem Content="Optosigma OSMS-120YAW"/>
                                                </ComboBox>
                                                <StackPanel Spacing="8" IsVisible="{Binding HardwareType, Converter={StaticResource SigmakokiRotationVisibleConverter}}">
                                                    <TextBox Text="{Binding SerialPortName}" Watermark="COM port (e.g. COM3)" FontSize="12"/>
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Text="HSC-103 axis (1–3)" FontSize="12" Foreground="#cccccc" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="1" Value="{Binding Hsc103AxisNumber}" Minimum="1" Maximum="3" Increment="1" FormatString="F0" FontSize="12"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Text="Degrees / pulse" FontSize="12" Foreground="#cccccc" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="1" Value="{Binding DegreesPerPulse}" Minimum="0.000001" Maximum="1" Increment="0.00001" FormatString="G9" FontSize="12"/>
                                                    </Grid>
                                                </StackPanel>
                                                <ComboBox IsVisible="False" SelectedIndex="{Binding SigmakokiController, Converter={StaticResource SigmakokiControllerToIndexConverter}}" PlaceholderText="Select Sigma Koki Model..." FontSize="12" Foreground="#ffffff" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="GIP-101B (1 axis)"/>
                                                    <ComboBoxItem Content="GSC-01 (1 axis)"/>
                                                    <ComboBoxItem Content="SHOT-302GS (2 axes)"/>
                                                    <ComboBoxItem Content="HSC-103 (3 axes)"/>
                                                    <ComboBoxItem Content="SHOT-304GS (4 axes)"/>
                                                    <ComboBoxItem Content="Hit-MV (4 axes)"/>
                                                    <ComboBoxItem Content="PGC-04 (4 axes)"/>
                                                </ComboBox>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Content="Connect" Command="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).ConnectStageCommand}" CommandParameter="{Binding}" Padding="12,6" FontSize="12" Foreground="#ffffff" IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}"/>
                                                    <Button Content="Disconnect" Command="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).DisconnectStageCommand}" CommandParameter="{Binding}" Padding="12,6" FontSize="12" Foreground="#ffffff" IsEnabled="{Binding IsConnected}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Movement Status -->
                <Border Background="#1a1a1a" BorderBrush="#303030" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <TextBlock Text="{Binding MovementStatus}" FontSize="12" Foreground="#ffffff" TextWrapping="Wrap"/>
                </Border>

                <!-- Action Buttons -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <Button Content="{Binding StartSequenceButtonText}" Command="{Binding StartSequenceCommand}" Padding="18,14" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" Background="#2e7d32" BorderBrush="#1b5e20" HorizontalAlignment="Stretch" IsEnabled="{Binding IsSequenceRunning, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="{Binding AbortSequenceButtonText}" Command="{Binding AbortSequenceCommand}" Foreground="#ffffff" Padding="18,14" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Stretch"
                                IsEnabled="{Binding IsSequenceRunning}"
                                Background="{Binding AbortSequenceButtonBackground}"/>
                    </StackPanel>
                </Border>

                <!-- Rotation calibration (batch) — hidden per UI spec; bindings/commands kept for future use -->
                <Border IsVisible="False"
                        Background="#252525"
                        BorderBrush="#404040"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Rotation calibration (NanoMeas.dll)"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#ffffff"/>
                        <TextBlock Text="{Binding RotationCalibVm.RotationDatasetHint}"
                                   FontSize="11"
                                   Foreground="#cccccc"
                                   TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Manual θ (deg) if no Rz axis:"
                                       VerticalAlignment="Center"
                                       Foreground="#ffffff"
                                       FontSize="12"
                                       Margin="0,0,12,0"/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding RotationCalibVm.ManualThetaDegrees}"
                                           Minimum="-360"
                                           Maximum="360"
                                           Increment="0.1"
                                           FormatString="F3"
                                           HorizontalAlignment="Stretch"/>
                        </Grid>
                        <TextBlock Text="Green button: Rz goes to 0° first, then each step saves frame_NNN.png + manifest.csv under .\storage\session_*. Configure → Run rotation calibration runs NanoMeas.dll on the newest session (≥12 frames)."
                                   FontSize="11"
                                   Foreground="#9e9e9e"
                                   TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Content="Clear sample list"
                                    Command="{Binding RotationCalibVm.ClearRotationSamplesCommand}"
                                    Padding="12,10"
                                    FontSize="13"
                                    HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1"
                                    Content="Import samples CSV"
                                    Command="{Binding RotationCalibVm.ImportRotationSamplesCsvCommand}"
                                    Padding="12,10"
                                    FontSize="13"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding RotationCalibVm.RotationSamples}"
                                 MinHeight="90"
                                 MaxHeight="190"
                                 Background="#1a1a1a"
                                 Foreground="#e0e0e0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:RotationCalibrationSample">
                                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" FontSize="11"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Error Log -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="20" Height="20" CornerRadius="2">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Fill="#ba68c8" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Error Log" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                        <ScrollViewer MaxHeight="150" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding ErrorLog}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" FontSize="11" Foreground="#ffffff" FontFamily="Consolas,Courier New" Background="Transparent"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
