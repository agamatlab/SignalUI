<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:singalUI.ViewModels"
             xmlns:m="using:singalUI.Models"
             xmlns:s="using:singalUI.Services"
             x:Class="singalUI.Views.CalibrationSetupView"
             x:DataType="vm:CalibrationSetupViewModel"
             Background="#1a1a1a">

    <Design.DataContext>
        <vm:CalibrationSetupViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*" ColumnDefinitions="*,300">

        <ScrollViewer Grid.Row="0" Grid.Column="0" Margin="16,16,8,16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
        
        <!-- Stage Position Display -->
        <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="Current Stage Position" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff"/>
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,18,8">
                        <TextBlock Text="X:" FontSize="14" FontWeight="Bold" Foreground="#aaaaaa" FontFamily="Consolas,Courier New" MinWidth="30"/>
                        <TextBlock Text="{Binding StagePositionX, StringFormat={}{0:F4}}" FontSize="14" FontWeight="Medium" Foreground="#dddddd" FontFamily="Consolas,Courier New" MinWidth="100"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,18,8">
                        <TextBlock Text="Y:" FontSize="14" FontWeight="Bold" Foreground="#aaaaaa" FontFamily="Consolas,Courier New" MinWidth="30"/>
                        <TextBlock Text="{Binding StagePositionY, StringFormat={}{0:F4}}" FontSize="14" FontWeight="Medium" Foreground="#dddddd" FontFamily="Consolas,Courier New" MinWidth="100"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,18,8">
                        <TextBlock Text="Z:" FontSize="14" FontWeight="Bold" Foreground="#aaaaaa" FontFamily="Consolas,Courier New" MinWidth="30"/>
                        <TextBlock Text="{Binding StagePositionZ, StringFormat={}{0:F4}}" FontSize="14" FontWeight="Medium" Foreground="#dddddd" FontFamily="Consolas,Courier New" MinWidth="100"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,18,8">
                        <TextBlock Text="Rx:" FontSize="14" FontWeight="Bold" Foreground="#aaaaaa" FontFamily="Consolas,Courier New" MinWidth="30"/>
                        <TextBlock Text="{Binding StagePositionRx, StringFormat={}{0:F4}}" FontSize="14" FontWeight="Medium" Foreground="#dddddd" FontFamily="Consolas,Courier New" MinWidth="100"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,18,8">
                        <TextBlock Text="Ry:" FontSize="14" FontWeight="Bold" Foreground="#aaaaaa" FontFamily="Consolas,Courier New" MinWidth="30"/>
                        <TextBlock Text="{Binding StagePositionRy, StringFormat={}{0:F4}}" FontSize="14" FontWeight="Medium" Foreground="#dddddd" FontFamily="Consolas,Courier New" MinWidth="100"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,18,8">
                        <TextBlock Text="Rz:" FontSize="14" FontWeight="Bold" Foreground="#aaaaaa" FontFamily="Consolas,Courier New" MinWidth="30"/>
                        <TextBlock Text="{Binding StagePositionRz, StringFormat={}{0:F4}}" FontSize="14" FontWeight="Medium" Foreground="#dddddd" FontFamily="Consolas,Courier New" MinWidth="100"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>
        
        <Border IsVisible="{Binding HelpModeActive}"
                Background="#1f2b1f"
                BorderBrush="#58ff9a"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8">
            <StackPanel Spacing="4">
                <TextBlock Text="Stage usage modes: Manual=single sample, Triggered=sample on new frame (+delay), Timed=sample every interval, Control=move stages by configured steps."
                           FontSize="12"
                           Foreground="#d6ffd9"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Default mode is Control for motion workflow; switch to Manual/Triggered/Timed for no-motion pose sampling."
                           FontSize="12"
                           Foreground="#d6ffd9"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <ItemsControl ItemsSource="{Binding StageMotionGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectedStageMotionGroup">
                    <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,12">
                        <StackPanel Spacing="0">
                            <TextBlock Text="{Binding ProductTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff" Margin="16,12,16,4" HorizontalAlignment="Left"/>

                            <Border IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).SamplingMode, Converter={StaticResource ControlModeVisibleConverter}, ConverterParameter=Invert}"
                                    Background="#252525" BorderThickness="0" Padding="0">
                                <Grid RowDefinitions="Auto,Auto,*">
                                    <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,10">
                                        <StackPanel Orientation="Horizontal" Spacing="20">
                                            <TextBlock Text="Movement Mode:" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Absolute" GroupName="{Binding MovementRadioGroup}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Relative" GroupName="{Binding MovementRadioGroup}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,12">
                                        <Grid ColumnDefinitions="50,70,140,120,80,140,140,140,140">
                                            <TextBlock Grid.Column="0" Text="On" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="1" Text="Axis" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="2" Text="Built-in Range" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="3" Text="Resolution" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="4" Text="Unit" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="5" Text="Position" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="Step Size" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="Points" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="8" Text="Range" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#303030" BorderThickness="0,0,0,1" Padding="16,10" Background="#252525">
                                                    <Grid ColumnDefinitions="50,70,140,120,80,140,140,140,140">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Axis}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding BuiltInRange}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Resolution}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding Unit}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="5" Value="{Binding TargetPosition, Mode=TwoWay}" Minimum="-1000000" Maximum="1000000" Increment="100" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}"/>
                                                        <Border Grid.Column="5" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}">
                                                            <TextBlock Text="{Binding CalculatedEndPosition, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Border Grid.Column="6" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}">
                                                            <TextBlock Text="{Binding AutoStepSize, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <NumericUpDown Grid.Column="6" Value="{Binding StepSize, Mode=TwoWay}" Minimum="0.001" Maximum="1000" Increment="1" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}"/>
                                                        <Border Grid.Column="7" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8">
                                                            <TextBlock Text="{Binding NumSteps}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <NumericUpDown Grid.Column="8" Value="{Binding Range, Mode=TwoWay}" Minimum="0" Maximum="1000000" Increment="1" FormatString="F2" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).SamplingMode, Converter={StaticResource ControlModeVisibleConverter}}"
                                    Background="#252525" BorderThickness="0" Padding="0">
                                <Grid RowDefinitions="Auto,Auto,*">
                                    <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,10">
                                        <StackPanel Orientation="Horizontal" Spacing="20">
                                            <TextBlock Text="Movement Mode:" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Absolute" GroupName="{Binding MovementRadioGroupB}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                            <RadioButton Content="Relative" GroupName="{Binding MovementRadioGroupB}" IsChecked="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Background="#2a2a2a" BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="16,12">
                                        <Grid ColumnDefinitions="50,70,140,120,80,140,140,140,140">
                                            <TextBlock Grid.Column="0" Text="On" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="1" Text="Axis" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="2" Text="Built-in Range" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="3" Text="Resolution" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="4" Text="Unit" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <TextBlock Grid.Column="5" Text="Position" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="Step Size" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="Points" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="8" Text="Range" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" TextAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#303030" BorderThickness="0,0,0,1" Padding="16,10" Background="#252525">
                                                    <Grid ColumnDefinitions="50,70,140,120,80,140,140,140,140">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Axis}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding BuiltInRange}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Resolution}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding Unit}" FontSize="14" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="5" Value="{Binding TargetPosition, Mode=TwoWay}" Minimum="-1000000" Maximum="1000000" Increment="100" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}"/>
                                                        <Border Grid.Column="5" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}">
                                                            <TextBlock Text="{Binding CalculatedEndPosition, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Border Grid.Column="6" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8"
                                                                IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute}">
                                                            <TextBlock Text="{Binding AutoStepSize, StringFormat={}{0:F2}}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <NumericUpDown Grid.Column="6" Value="{Binding StepSize, Mode=TwoWay}" Minimum="0.001" Maximum="1000" Increment="1" FormatString="F1" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                       IsVisible="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).MovementModeAbsolute, Converter={StaticResource InverseBoolConverter}}"/>
                                                        <Border Grid.Column="7" Background="#1a1a1a" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Padding="0,8,0,8">
                                                            <TextBlock Text="{Binding NumSteps}" FontSize="14" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <NumericUpDown Grid.Column="8" Value="{Binding Range, Mode=TwoWay}" Minimum="0" Maximum="1000000" Increment="1" FormatString="F2" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </StackPanel>
        </ScrollViewer>

        <!-- Right Panel - Scrollable -->
        <ScrollViewer Grid.Row="0" Grid.Column="1" Margin="8,16,16,16">
            <StackPanel Spacing="12">
                <Border IsVisible="{Binding HelpModeActive}"
                        Background="#1f2b1f"
                        BorderBrush="#58ff9a"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,8">
                    <TextBlock Text="Stage connection: Add a controller, select hardware/COM, click Connect, verify green status, then run Start Sequence."
                               FontSize="12"
                               Foreground="#d6ffd9"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Stage Controllers -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Stage Controllers" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Add" Command="{Binding AddStageCommand}" Padding="10,6" FontSize="12" Foreground="#ffffff" HorizontalAlignment="Right"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding StageWrappers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Id, StringFormat='Stage {0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"/>
                                            <Ellipse Grid.Row="0" Grid.Column="1" Width="12" Height="12" VerticalAlignment="Center" Margin="8,0,8,0" Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusColorConverter}}" Stroke="#505050" StrokeThickness="1"/>
                                            <Button Grid.Row="0" Grid.Column="2" Command="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).RemoveStageCommand}" CommandParameter="{Binding}" Padding="4" Background="Transparent" BorderThickness="0" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0">
                                                <Path Width="18" Height="18" Fill="#ff4444" Data="M9 3h6l1 1h4v2H4V4h4l1-1zm-3 5h14l-1 14H7L6 8zm3 3v9h2v-9H9zm4 0v9h2v-9h-2z" Stretch="Uniform"/>
                                            </Button>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Vertical" Spacing="8" Margin="0,8,0,0">
                                                <ComboBox SelectedIndex="{Binding HardwareType, Converter={StaticResource StageHardwareToIndexConverter}}" PlaceholderText="Select Hardware..." FontSize="12" Foreground="#ffffff" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="None"/>
                                                    <ComboBoxItem Content="PI 6-dof"/>
                                                    <ComboBoxItem Content="Optosigma OSMS26-100(X)"/>
                                                    <ComboBoxItem Content="Optosigma OSMS-120YAW"/>
                                                </ComboBox>
                                                <StackPanel Spacing="8" IsVisible="{Binding HardwareType, Converter={StaticResource SigmakokiRotationVisibleConverter}}">
                                                    <TextBox Text="{Binding SerialPortName}" Watermark="COM port (e.g. COM3)" FontSize="12"/>
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Text="HSC-103 axis (1–3)" FontSize="12" Foreground="#cccccc" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="1" Value="{Binding Hsc103AxisNumber}" Minimum="1" Maximum="3" Increment="1" FormatString="F0" FontSize="12"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Text="Degrees / pulse" FontSize="12" Foreground="#cccccc" VerticalAlignment="Center"/>
                                                        <NumericUpDown Grid.Column="1" Value="{Binding DegreesPerPulse}" Minimum="0.000001" Maximum="1" Increment="0.00001" FormatString="G9" FontSize="12"/>
                                                    </Grid>
                                                </StackPanel>
                                                <ComboBox IsVisible="False" SelectedIndex="{Binding SigmakokiController, Converter={StaticResource SigmakokiControllerToIndexConverter}}" PlaceholderText="Select Sigma Koki Model..." FontSize="12" Foreground="#ffffff" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="GIP-101B (1 axis)"/>
                                                    <ComboBoxItem Content="GSC-01 (1 axis)"/>
                                                    <ComboBoxItem Content="SHOT-302GS (2 axes)"/>
                                                    <ComboBoxItem Content="HSC-103 (3 axes)"/>
                                                    <ComboBoxItem Content="SHOT-304GS (4 axes)"/>
                                                    <ComboBoxItem Content="Hit-MV (4 axes)"/>
                                                    <ComboBoxItem Content="PGC-04 (4 axes)"/>
                                                </ComboBox>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Content="Connect" Command="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).ConnectStageCommand}" CommandParameter="{Binding}" Padding="12,6" FontSize="12" Foreground="#ffffff" IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}"/>
                                                    <Button Content="Disconnect" Command="{Binding $parent[UserControl].((vm:CalibrationSetupViewModel)DataContext).DisconnectStageCommand}" CommandParameter="{Binding}" Padding="12,6" FontSize="12" Foreground="#ffffff" IsEnabled="{Binding IsConnected}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Movement Status -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Stage" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff"/>
                        <Border Background="#2a2a2a" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <RadioButton Content="Manual"
                                             GroupName="SamplingMode"
                                             IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Manual}"
                                             FontSize="14"
                                             Foreground="#ffffff"/>
                                <RadioButton Content="Triggered"
                                             GroupName="SamplingMode"
                                             IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Triggered}"
                                             FontSize="14"
                                             Foreground="#ffffff"/>
                                <RadioButton Content="Timed"
                                             GroupName="SamplingMode"
                                             IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Timed}"
                                             FontSize="14"
                                             Foreground="#ffffff"/>
                                <RadioButton Content="Control"
                                             GroupName="SamplingMode"
                                             IsChecked="{Binding SamplingMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Control}"
                                             FontSize="14"
                                             Foreground="#ffffff"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="8"
                                    IsVisible="{Binding SamplingMode, Converter={StaticResource SamplingModeVisibleConverter}}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="Duration (s):" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding TimedDuration}" Minimum="1" Maximum="3600" Increment="1" FormatString="F0" FontSize="13" HorizontalAlignment="Stretch"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="Interval (s):" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding TimedInterval}" Minimum="0.1" Maximum="10" Increment="0.1" FormatString="F1" FontSize="13" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"
                              IsVisible="{Binding SamplingMode, Converter={StaticResource TriggeredModeVisibleConverter}}">
                            <TextBlock Grid.Column="0" Text="Delay (ms):" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding TriggeredDelay}" Minimum="0" Maximum="10000" Increment="1" FormatString="F0" FontSize="13" HorizontalAlignment="Stretch"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"
                              IsVisible="{Binding SamplingMode, Converter={StaticResource ControlModeVisibleConverter}}">
                            <TextBlock Grid.Column="0" Text="Delay (ms):" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding ControlDelay}" Minimum="0" Maximum="10000" Increment="1" FormatString="F0" FontSize="13" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#1a1a1a" BorderBrush="#303030" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <TextBlock Text="{Binding MovementStatus}" FontSize="12" Foreground="#ffffff" TextWrapping="Wrap"/>
                </Border>

                <!-- Action Buttons -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Button Content="{Binding SequenceActionButtonText}"
                            Command="{Binding StartOrAbortSequenceCommand}"
                            Padding="18,14"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#ffffff"
                            Background="{Binding SequenceActionButtonBackground}"
                            HorizontalAlignment="Stretch"/>
                </Border>

                <!-- Error Log -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="20" Height="20" CornerRadius="2">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Fill="#ba68c8" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Error Log" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                        <ScrollViewer MaxHeight="150" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding ErrorLog}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" FontSize="11" Foreground="#ffffff" FontFamily="Consolas,Courier New" Background="Transparent"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
