<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:singalUI.ViewModels"
             xmlns:v="using:singalUI.Views"
             x:Class="singalUI.Views.CollapsiblePanelView"
             x:CompileBindings="False"
             Background="#252525"
             BorderBrush="#404040"
             BorderThickness="1"
             CornerRadius="8"
             Padding="0">

    <Design.DataContext>
        <vm:CollapsiblePanelViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="0">
        <!-- Header with Collapse Button -->
        <Border Background="#2a2a2a"
                BorderBrush="#404040"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                CornerRadius="8,8,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="2">
                    <Path Data="{Binding IconPath, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Fill="#e0e0e0"
                          Stretch="Uniform"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#ffffff"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <Button Grid.Column="2"
                        Content="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToArrowConverter}}"
                        Click="OnToggleClick"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Background="Transparent"
                        Foreground="#ffffff"
                        BorderBrush="Transparent"
                        FontSize="18"/>
            </Grid>
        </Border>

        <!-- Content (collapsible) -->
        <Border IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Background="Transparent"
                Padding="20"
                CornerRadius="0,0,8,8">
            <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Border>
    </StackPanel>
</UserControl>
