<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:singalUI.ViewModels"
             xmlns:v="using:singalUI.Views"
             xmlns:m="using:singalUI.Models"
             x:Class="singalUI.Views.ConfigView"
             x:DataType="vm:ConfigViewModel"
             Background="#1a1a1a">

    <Design.DataContext>
        <vm:ConfigViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,380">
        <!-- Header Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#2a2a2a"
                BorderBrush="#404040"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Width="24" Height="24" CornerRadius="3">
                        <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L5.09 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.04.64.09.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                              Fill="#ffffff" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="Pattern Analysis Configuration"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#ffffff"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Border Background="#1a1a1a"
                            BorderBrush="#303030"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="{Binding EstimatorStatus, Converter={StaticResource StatusColorConverter}}"/>
                            <TextBlock Text="{Binding EstimatorStatus}"
                                       FontSize="13"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Content Area - Configuration Panels -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="16,16,8,16">
            <StackPanel Spacing="16">

                <!-- Pattern Analysis Panel -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M4 4h16v16H4V4zm2 2v12h12V6H6zm2 2h8v8H8V8z"
                                      Fill="#6a9eff" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Pattern Analysis Configuration"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <!-- Pattern Type Selection -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Pattern Type"
                                       FontSize="13"
                                       Foreground="#ffffff"/>
                            <ComboBox SelectedIndex="{Binding SelectedPatternType}"
                                      PlaceholderText="Select pattern type"
                                      FontSize="13"
                                      Padding="10,8"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="200">
                                <ComboBoxItem Content="Checker Board (Calibration)"/>
                                <ComboBoxItem Content="Dot Grid (HMF Coded Target)"/>
                                <ComboBoxItem Content="Circular Grid"/>
                                <ComboBoxItem Content="Concentric Circles"/>
                                <ComboBoxItem Content="Asymmetric Circles"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- HMF Pattern Configuration -->
                        <Border Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Pitch X (mm):"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="0" Grid.Column="1"
                                               Value="{Binding PitchX}"
                                               Minimum="0.1"
                                               Maximum="100"
                                               Increment="0.1"
                                               FormatString="F2"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Pitch Y (mm):"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="1" Grid.Column="1"
                                               Value="{Binding PitchY}"
                                               Minimum="0.1"
                                               Maximum="100"
                                               Increment="0.1"
                                               FormatString="F2"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Components X:"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="2" Grid.Column="1"
                                               Value="{Binding ComponentsX}"
                                               Minimum="3"
                                               Maximum="50"
                                               Increment="1"
                                               FormatString="F0"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Components Y:"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="3" Grid.Column="1"
                                               Value="{Binding ComponentsY}"
                                               Minimum="3"
                                               Maximum="50"
                                               Increment="1"
                                               FormatString="F0"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Camera Intrinsics Panel -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M9.4 10.5l4.8-4.8c.4-.4.4-1 0-1.4-.4-.4-1-.4-1.4 0l-5.5 5.5c-.4.4-.4 1 0 1.4l5.5 5.5c.2.2.5.3.7.3s.5-.1.7-.3c.4-.4.4-1 0-1.4L9.4 10.5z M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"
                                      Fill="#4fc3f7" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Camera Intrinsics"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <!-- Focal Length & Pixel Size -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                                <TextBlock Text="Focal Length (mm)"
                                           FontSize="13"
                                           Foreground="#ffffff"/>
                                <NumericUpDown Value="{Binding FocalLength}"
                                               Minimum="1"
                                               Maximum="200"
                                               Increment="0.5"
                                               FormatString="F2"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8" Margin="12,0,0,0">
                                <TextBlock Text="Pixel Size (mm)"
                                           FontSize="13"
                                           Foreground="#ffffff"/>
                                <NumericUpDown Value="{Binding PixelSize}"
                                               Minimum="0.001"
                                               Maximum="0.1"
                                               Increment="0.001"
                                               FormatString="F4"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Principal Point -->
                        <Border Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Fx (pixels):"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="0" Grid.Column="1"
                                               Value="{Binding Fx}"
                                               Minimum="100"
                                               Maximum="10000"
                                               Increment="10"
                                               FormatString="F1"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Fy (pixels):"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="1" Grid.Column="1"
                                               Value="{Binding Fy}"
                                               Minimum="100"
                                               Maximum="10000"
                                               Increment="10"
                                               FormatString="F1"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Cx (pixels):"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                <NumericUpDown Grid.Row="2" Grid.Column="1"
                                               Value="{Binding Cx}"
                                               Minimum="0"
                                               Maximum="5000"
                                               Increment="10"
                                               FormatString="F1"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Cy (pixels):"
                                           FontSize="13"
                                           Foreground="#ffffff"/>
                                <NumericUpDown Grid.Row="3" Grid.Column="1"
                                               Value="{Binding Cy}"
                                               Minimum="0"
                                               Maximum="5000"
                                               Increment="10"
                                               FormatString="F1"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Algorithm Parameters Panel -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                      Fill="#81c784" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Algorithm Parameters"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Window Size"
                                       FontSize="13"
                                       Foreground="#ffffff"/>
                            <NumericUpDown Value="{Binding WindowSize}"
                                           Minimum="1"
                                           Maximum="50"
                                           Increment="0.5"
                                           FormatString="F1"
                                           FontSize="13"
                                           Padding="8,4"
                                           HorizontalAlignment="Stretch"
                                           Foreground="#ffffff"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- HMF File Configuration -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                                      Fill="#ab47bc" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="HMF Pattern Files (12x12)"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <!-- Enable Custom Paths -->
                        <CheckBox IsChecked="{Binding UseCustomHmfPaths}"
                                  Content="Use custom HMF file paths"
                                  FontSize="13"
                                  Foreground="#ffffff"/>

                        <TextBlock Text="If unchecked, the system will look for 12+12_G.txt, 12+12_X.txt, and 12+12_Y.txt in the Archive folder relative to the captured image."
                                   FontSize="11"
                                   Foreground="#aaaaaa"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !UseCustomHmfPaths}"/>

                        <!-- HMF G File -->
                        <Border Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                IsVisible="{Binding UseCustomHmfPaths}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="HMF G File (12+12_G.txt)"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding HmfGPath}"
                                             IsReadOnly="True"
                                             FontSize="12"
                                             Padding="8,6"
                                             Watermark="No file selected"/>
                                    <Button Grid.Column="1"
                                            Content="Browse..."
                                            Command="{Binding BrowseHmfGFileCommand}"
                                            Padding="12,6"
                                            FontSize="12"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- HMF X File -->
                        <Border Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                IsVisible="{Binding UseCustomHmfPaths}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="HMF X File (12+12_X.txt)"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding HmfXPath}"
                                             IsReadOnly="True"
                                             FontSize="12"
                                             Padding="8,6"
                                             Watermark="No file selected"/>
                                    <Button Grid.Column="1"
                                            Content="Browse..."
                                            Command="{Binding BrowseHmfXFileCommand}"
                                            Padding="12,6"
                                            FontSize="12"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- HMF Y File -->
                        <Border Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                IsVisible="{Binding UseCustomHmfPaths}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="HMF Y File (12+12_Y.txt)"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding HmfYPath}"
                                             IsReadOnly="True"
                                             FontSize="12"
                                             Padding="8,6"
                                             Watermark="No file selected"/>
                                    <Button Grid.Column="1"
                                            Content="Browse..."
                                            Command="{Binding BrowseHmfYFileCommand}"
                                            Padding="12,6"
                                            FontSize="12"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Test Data Configuration -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                                      Fill="#ffb74d" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Test Image Configuration"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                                <TextBlock Text="Image Width"
                                           FontSize="13"
                                           Foreground="#ffffff"/>
                                <NumericUpDown Value="{Binding ImageWidth}"
                                               Minimum="100"
                                               Maximum="4096"
                                               Increment="10"
                                               FormatString="F0"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8" Margin="12,0,0,0">
                                <TextBlock Text="Image Height"
                                           FontSize="13"
                                           Foreground="#ffffff"/>
                                <NumericUpDown Value="{Binding ImageHeight}"
                                               Minimum="100"
                                               Maximum="4096"
                                               Increment="10"
                                               FormatString="F0"
                                               FontSize="13"
                                               Padding="8,4"
                                               HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Note: In production, this will use real camera frames from CameraSetupView."
                                   FontSize="11"
                                   Foreground="#ffffff"
                                   FontStyle="Italic"/>
                        <TextBlock Text="{Binding CameraResolutionStatus}"
                                   FontSize="11"
                                   Foreground="#8ec5ff"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel - Results & Actions -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="8,16,16,16">
            <StackPanel Spacing="16">

                <!-- Pose Estimation Results -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14h-2v-4h2v4zm0-6h-2V7h2v4z"
                                      Fill="#e57373" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Pose estimation results"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>
                            </StackPanel>
                        </Grid>

                        <!-- Status Indicator -->
                        <Border Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <Grid ColumnDefinitions="Auto,*">
                                <Ellipse Grid.Column="0" Width="10" Height="10"
                                         Fill="{Binding ResultStatusColor}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ResultStatusMessage}"
                                           FontSize="13"
                                           Foreground="#ffffff"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Rotation Data -->
                        <Border IsVisible="{Binding HasResults}"
                                Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Rotation (degrees)"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Rx:"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,12,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Rx, StringFormat={}{0:F4}°}"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Ry:"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,12,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Ry, StringFormat={}{0:F4}°}"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Rz:"
                                               FontSize="12"
                                               Foreground="#ffffff"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Rz, StringFormat={}{0:F4}°}"
                                               FontSize="12"
                                               Foreground="#ffffff"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Translation Data -->
                        <Border IsVisible="{Binding HasResults}"
                                Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Translation (millimeters)"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Tx:"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,12,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Tx, StringFormat={}{0:F3} mm}"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Ty:"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,12,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Ty, StringFormat={}{0:F3} mm}"
                                               FontSize="12"
                                               Foreground="#ffffff"
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Tz:"
                                               FontSize="12"
                                               Foreground="#ffffff"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Tz, StringFormat={}{0:F3} mm}"
                                               FontSize="12"
                                               Foreground="#ffffff"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Raw Data -->
                        <Border IsVisible="{Binding HasResults}"
                                Background="#1a1a1a"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Raw Pose Data"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#ffffff"/>
                                <TextBlock Text="{Binding RawPoseData}"
                                           FontSize="11"
                                           Foreground="#ffffff"
                                           FontFamily="Consolas,Courier New"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Error Log -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                      Fill="#ba68c8" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Error Log"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <ScrollViewer MaxHeight="300" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding ErrorLog}"
                                       IsReadOnly="True"
                                       AcceptsReturn="True"
                                       TextWrapping="Wrap"
                                       BorderThickness="0"
                                       FontSize="11"
                                       Foreground="#ffffff"
                                       FontFamily="Consolas,Courier New"
                                       Background="Transparent"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M8 5v14l11-7z"
                                      Fill="#4fc3f7" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Actions"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <Button Content="{Binding RunPoseButtonText}"
                                Command="{Binding RunPoseEstimationCommand}"
                                IsEnabled="{Binding IsPoseEstimationRunning, Converter={StaticResource InverseBoolConverter}}"
                                Padding="16,12"
                                FontSize="14"
                                HorizontalAlignment="Stretch"
                                Background="#2e7d32"
                                Foreground="#ffffff"/>

                        <TextBlock Text="Native pose estimation can take around 30-60 seconds on a full frame."
                                   IsVisible="{Binding IsPoseEstimationRunning}"
                                   FontSize="12"
                                   Foreground="#ffcc80"
                                   TextWrapping="Wrap"/>

                        <Button Content="Get Error Information"
                                Command="{Binding GetErrorCommand}"
                                Padding="16,12"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>

                        <Button Content="Reset to Defaults"
                                Command="{Binding ResetDefaultsCommand}"
                                Padding="16,12"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>

                        <Button Content="Clear Results"
                                Command="{Binding ClearResultsCommand}"
                                Padding="16,12"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Configuration Presets -->
                <Border Background="#252525" BorderBrush="#404040" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <!-- Section Header -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,2,0,0">
                                <Path Data="M4 4h16v16H4V4zm2 2v12h12V6H6zm2 2h8v8H8V8z"
                                      Fill="#9575cd" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="Quick Presets"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#ffffff"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <Button Content="Load Default Calibration"
                                Command="{Binding LoadDefaultPresetCommand}"
                                Padding="16,12"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>

                        <Button Content="Load High Precision Settings"
                                Command="{Binding LoadHighPrecisionPresetCommand}"
                                Padding="16,12"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
